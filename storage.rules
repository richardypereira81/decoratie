rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /{allPaths=**} {
      allow read, write: if isSignedIn();
    }
  }
}
